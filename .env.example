# Anthropic (report narration)
ANTHROPIC_API_KEY=sk-ant-...

# All three portals log in through a headless browser with the site owner's
# username/password — no API key or token required.

# SolarEdge (monitoring.solaredge.com)
SOLAREDGE_USERNAME=
SOLAREDGE_PASSWORD=

# Growatt (server.growatt.com)
GROWATT_USERNAME=
GROWATT_PASSWORD=
# Optional alternative to the browser login: OpenAPI v1 token (mode: token).
# GROWATT_TOKEN=

# SMA Sunny Portal (SMA ID / Keycloak login)
SMA_USERNAME=
SMA_PASSWORD=

# Set to 0 to watch the browser during a run (default headless).
# SOLAR_HEADLESS=1
